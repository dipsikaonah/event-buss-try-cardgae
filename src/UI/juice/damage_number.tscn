[gd_scene format=3 uid="uid://dp55yir5oss2r"]

[sub_resource type="GDScript" id="GDScript_ktxi1"]
resource_name = "flaotingnumber"
script/source = "extends Label

@export var float_height := 60.0
@export var duration := 0.6

func _ready():
	modulate.a = 1.0
	scale = Vector2.ONE

	# small random offset so numbers don't overlap perfectly
	position += Vector2(randf_range(-10, 10), 0)

	var tw = create_tween()

	# pop in
	tw.tween_property(self, \"scale\", Vector2(1.3, 1.3), 0.1)\\
		.set_trans(Tween.TRANS_BACK)

	tw.tween_property(self, \"scale\", Vector2.ONE, 0.1)

	# float + fade at the same time
	tw.parallel().tween_property(
		self,
		\"position:y\",
		position.y - float_height,
		duration
	)

	tw.parallel().tween_property(
		self,
		\"modulate:a\",
		0.0,
		duration
	)

	# delete when finished (alpha already reached 0)
	await tw.finished
	queue_free()
"

